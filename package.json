  "description": "GoHighLevel MCP server exposing CRM, pipeline, conversation, calendar, workflow, and user tools over stdio.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
