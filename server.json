{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.snack-jpg/ghl-mcp",
  "title": "GoHighLevel MCP Server",
  "description": "50 MCP tools for GoHighLevel CRM — contacts, pipelines, conversations, and more.",
  "repository": {
    "url": "https://github.com/Snack-JPG/ghl-mcp",
    "source": "github"
  },
  "version": "1.0.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "ghl-mcp",
      "version": "1.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GHL_API_TOKEN",
          "description": "GoHighLevel Private Integration token or OAuth access token",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "GHL_LOCATION_ID",
          "description": "GoHighLevel location or sub-account ID",
          "isRequired": true,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
